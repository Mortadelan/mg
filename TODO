/* 
 * highlightbuffer - loop through current buffer's lines and highlight
 * them using highlight_line, provided by kat
 */
int
hlbuffer()
{
	struct buffer *bp = curbp;
	struct line *lp;
	int s, llen, lnum = 0;
	
	for (lp = bfirstlp(bp); lp != bp->b_headp; lp = lforw(lp)) {
		lnum++;
		llen = llength(lp);
		if (llen >= BUFSIZE)
			return (FALSE);
		
		highlight-line(lp->l_text, *bp, llen);
	}
	cleanup();
	return (TRUE);
}

struct line {
	[...]
	char    *l_text; # char array!!!!
};

